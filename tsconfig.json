{
  "compilerOptions": {
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "pretty": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": false,
    "strictNullChecks": true,
    "target": "ES2022",
    "types": [
      "node"
    ],
    "rootDir": "../../../src",
    "outDir": "../../../dist"
  },
  "exclude": [
    "../../../node_modules/**/*",
    "node_modules/**/*",
    "../../../dist/**/*",
    "dist/**/*"
  ],
  "compileOnSave": false
}
